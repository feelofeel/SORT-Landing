---
import Logo from "@/components/ui/Logo.astro";
import ToTop from "@/components/widgets/ToTop.astro";
import { siteConfig, socialLinks } from "@/config/site.js";

const currentYear = new Date().getFullYear();

const footerLinks = {
  product: [
    { name: "Можливості", url: "/#features" },
    { name: "Як це працює", url: "/#how" },
    { name: "Ціни", url: "/#pricing" },
    { name: "Часті запитання", url: "/#faq" },
  ],
  contact: [
    { name: "Telegram @feelofeel", url: siteConfig.telegram },
    { name: "Підключити заклад", url: "/#contact" },
    { name: "Poster", url: "https://joinposter.com" },
  ],
};
---

<section class="text-gray-700 border-t mt-20 md:mt-32 border-dashed border-primary/15 dark:border-primary-dark/15 border-[.75px]">
  <div class="container mx-auto px-7 max-w-7xl py-12 md:py-16">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8 mb-12">
      <div class="max-w-sm">
        <Logo />
        <p class="mt-4 text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">
          Шар обізнаності про терміни придатності поверх Poster. Не інвентаризація, не заміна POS, не HACCP — лише рішення про терміни, вчасно й в один дотик.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-8 md:gap-16">
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4">Продукт</h4>
          <ul class="space-y-3">
            {footerLinks.product.map((link) => (
              <li>
                <a href={link.url} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4">Контакт</h4>
          <ul class="space-y-3">
            {footerLinks.contact.map((link) => (
              <li>
                <a href={link.url} target="_blank" class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="border-t border-dashed border-primary/10 dark:border-primary-dark/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-neutral-400 dark:text-neutral-500">
        © {currentYear} {siteConfig.author}. Працює поверх Poster.
      </p>
      <span class="inline-flex justify-center space-x-4">
        {socialLinks.map((social) => (
          <a
            href={social.url}
            target="_blank"
            class="footer-social-icon-link text-neutral-400 dark:text-neutral-500 hover:text-primary dark:hover:text-primary-light transition-colors duration-200"
            title={social.name}
          >
            <span class="sr-only">{social.name}</span>
            <div class="footer-social-icon">
              <Fragment set:html={social.icon} />
            </div>
          </a>
        ))}
      </span>
    </div>
  </div>
</section>

<ToTop />

<style is:global>
  .footer-social-icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .footer-social-icon svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
  .footer-social-icon-link:hover .ic-telegram {
    color: #229ED9;
  }
</style>
