---
import Logo from "@/components/ui/Logo.astro";
import ToTop from "@/components/widgets/ToTop.astro";
import { siteConfig, socialLinks } from "@/config/site.js";
import { type Lang, getContent, localizePath } from "@/i18n";

interface Props {
	lang?: Lang;
}
const { lang = "uk" } = Astro.props;
const c = getContent(lang);
const currentYear = new Date().getFullYear();

const footerLinks = {
	product: c.footer.productLinks.map((l) => ({
		...l,
		url: localizePath(l.url, lang),
	})),
	contact: c.footer.contactLinks.map((l) => ({
		...l,
		url: localizePath(l.url, lang),
	})),
};
---

<section class="text-gray-700 border-t mt-20 md:mt-32 border-dashed border-primary/15 dark:border-primary-dark/15 border-[.75px]">
  <div class="container mx-auto px-7 max-w-7xl py-12 md:py-16">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8 mb-12">
      <div class="max-w-sm">
        <Logo lang={lang} />
        <p class="mt-4 text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">
          {c.footer.tagline}
        </p>
      </div>

      <div class="grid grid-cols-2 gap-8 md:gap-16">
        <div>
          <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4">{c.footer.productHeading}</h3>
          <ul class="space-y-3">
            {footerLinks.product.map((link) => (
              <li>
                <a href={link.url} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4">{c.footer.contactHeading}</h3>
          <ul class="space-y-3">
            {footerLinks.contact.map((link) => (
              <li>
                <a href={link.url} target={link.external ? "_blank" : undefined} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="border-t border-dashed border-primary/10 dark:border-primary-dark/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-neutral-600 dark:text-neutral-400">
        © {currentYear} {siteConfig.author}{c.footer.rights ? `. ${c.footer.rights}` : "."}
      </p>
      <span class="inline-flex justify-center space-x-4">
        {socialLinks.map((social) => (
          <a
            href={social.url}
            target="_blank"
            class="footer-social-icon-link text-neutral-600 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200"
            title={social.name}
          >
            <span class="sr-only">{social.name}</span>
            <div class="footer-social-icon">
              <Fragment set:html={social.icon} />
            </div>
          </a>
        ))}
      </span>
    </div>
  </div>
</section>

<ToTop />

<style is:global>
  .footer-social-icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .footer-social-icon svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
  .footer-social-icon-link:hover .ic-telegram {
    color: #229ED9;
  }
</style>
