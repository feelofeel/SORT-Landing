---
import { ChevronDown, ChevronLeft, ChevronRight, ChevronUp } from "@lucide/astro";

interface Step {
	n: string;
	title: string;
	desc: string;
}

interface Props {
	steps: Step[];
}

const { steps } = Astro.props;

// SVG Repo icons — MIT licensed (svgrepo.com)
const icons = [
	// 1: Delivery truck
	`<svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path fill-rule="evenodd" clip-rule="evenodd" d="M11 2H0V13H2C2 14.1046 2.89543 15 4 15C5.10457 15 6 14.1046 6 13H10C10 14.1046 10.8954 15 12 15C13.1046 15 14 14.1046 14 13H16V8C16 6.34315 14.6569 5 13 5H11V2ZM11 7V9H14V7H11Z" fill="currentColor"/>
  </svg>`,

	// 2: Sort arrows
	`<svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M8 0L2 6V7H14V6L8 0Z" fill="currentColor"/>
    <path d="M8 16L2 10V9H14V10L8 16Z" fill="currentColor"/>
  </svg>`,

	// 3: Lines magnifying glass
	`<svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M15 1H1V3H15V1Z" fill="currentColor"/>
    <path d="M11 5H1V7H6.52779C7.62643 5.7725 9.223 5 11 5Z" fill="currentColor"/>
    <path d="M5.34141 13C5.60482 13.7452 6.01127 14.4229 6.52779 15H1V13H5.34141Z" fill="currentColor"/>
    <path d="M5.34141 9C5.12031 9.62556 5 10.2987 5 11H1V9H5.34141Z" fill="currentColor"/>
    <path d="M15 11C15 11.7418 14.7981 12.4365 14.4462 13.032L15.9571 14.5429L14.5429 15.9571L13.032 14.4462C12.4365 14.7981 11.7418 15 11 15C8.79086 15 7 13.2091 7 11C7 8.79086 8.79086 7 11 7C13.2091 7 15 8.79086 15 11Z" fill="currentColor"/>
  </svg>`,

	// 4: Tapping hand
	`<svg viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M8 3V0H6V3H8Z"/>
    <path d="M9.87868 12H7V15H10.6109C13.5872 15 16 12.5872 16 9.61091C16 8.18164 15.4322 6.8109 14.4216 5.80025L13.3322 4.71088L8.8322 6.71088L6.56066 4.43934L4.43934 6.56066L9.87868 12Z"/>
    <path d="M0 6H3V8H0V6Z"/>
    <path d="M3.29289 4.70711L0.792893 2.20711L2.20711 0.792893L4.70711 3.29289L3.29289 4.70711Z"/>
  </svg>`,
];

const arrowStyle = "color: var(--color-primary-light)";
const iconStyle = "color: var(--color-primary-light)";

const cardBase = "p-4 rounded-2xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700";
---

<!-- Mobile: single column, sequential -->
<div class="md:hidden grid grid-cols-1 gap-0 mt-6 max-w-sm mx-auto">
  {steps.map((s, i) => (
    <div>
      <div class={cardBase}>
        <div class="flex items-start gap-3 mb-3">
          <div class="shrink-0 w-8 h-8 rounded-lg bg-primary text-white font-brand text-sm flex items-center justify-center">
            {s.n}
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100 mb-0.5">{s.title}</h3>
            <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">{s.desc}</p>
          </div>
        </div>
        <div class="flex justify-center" style={iconStyle}>
          <div class="w-8 h-8" set:html={icons[i]} />
        </div>
      </div>
      {i < steps.length - 1 && (
        <div class="flex justify-center py-1" style={arrowStyle}>
          <ChevronDown size={18} strokeWidth={2.5} />
        </div>
      )}
    </div>
  ))}
</div>

<!-- Desktop: 2×2 grid with SORT-style chevron arrows in the gaps -->
<div class="hidden md:grid mt-6 max-w-2xl mx-auto"
     style="grid-template-columns: 1fr 44px 1fr; grid-template-rows: auto 40px auto; gap: 0;">

  <!-- Row 1, col 1: step 1 -->
  <div class={`${cardBase} m-1.5`}>
    <div class="flex items-start gap-3 mb-4">
      <div class="shrink-0 w-9 h-9 rounded-xl bg-primary text-white font-brand text-base flex items-center justify-center">1</div>
      <div class="min-w-0">
        <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100 mb-1">{steps[0].title}</h3>
        <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">{steps[0].desc}</p>
      </div>
    </div>
    <div class="flex justify-center" style={iconStyle}>
      <div class="w-10 h-10" set:html={icons[0]} />
    </div>
  </div>

  <!-- Row 1, col 2: right arrow -->
  <div class="flex items-center justify-center" style={`grid-row:1; grid-column:2; ${arrowStyle}`}>
    <ChevronRight size={28} strokeWidth={2.5} />
  </div>

  <!-- Row 1, col 3: step 2 -->
  <div class={`${cardBase} m-1.5`}>
    <div class="flex items-start gap-3 mb-4">
      <div class="shrink-0 w-9 h-9 rounded-xl bg-primary text-white font-brand text-base flex items-center justify-center">2</div>
      <div class="min-w-0">
        <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100 mb-1">{steps[1].title}</h3>
        <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">{steps[1].desc}</p>
      </div>
    </div>
    <div class="flex justify-center" style={iconStyle}>
      <div class="w-10 h-10" set:html={icons[1]} />
    </div>
  </div>

  <!-- Row 2: up chevron · empty · down chevron -->
  <div class="flex items-center justify-center" style={`grid-row:2; grid-column:1; ${arrowStyle}`}>
    <ChevronUp size={28} strokeWidth={2.5} />
  </div>
  <div style="grid-row:2; grid-column:2;"></div>
  <div class="flex items-center justify-center" style={`grid-row:2; grid-column:3; ${arrowStyle}`}>
    <ChevronDown size={28} strokeWidth={2.5} />
  </div>

  <!-- Row 3, col 1: step 4 -->
  <div class={`${cardBase} m-1.5`}>
    <div class="flex items-start gap-3 mb-4">
      <div class="shrink-0 w-9 h-9 rounded-xl bg-primary text-white font-brand text-base flex items-center justify-center">4</div>
      <div class="min-w-0">
        <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100 mb-1">{steps[3].title}</h3>
        <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">{steps[3].desc}</p>
      </div>
    </div>
    <div class="flex justify-center" style={iconStyle}>
      <div class="w-10 h-10" set:html={icons[3]} />
    </div>
  </div>

  <!-- Row 3, col 2: left arrow -->
  <div class="flex items-center justify-center" style={`grid-row:3; grid-column:2; ${arrowStyle}`}>
    <ChevronLeft size={28} strokeWidth={2.5} />
  </div>

  <!-- Row 3, col 3: step 3 -->
  <div class={`${cardBase} m-1.5`}>
    <div class="flex items-start gap-3 mb-4">
      <div class="shrink-0 w-9 h-9 rounded-xl bg-primary text-white font-brand text-base flex items-center justify-center">3</div>
      <div class="min-w-0">
        <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100 mb-1">{steps[2].title}</h3>
        <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">{steps[2].desc}</p>
      </div>
    </div>
    <div class="flex justify-center" style={iconStyle}>
      <div class="w-10 h-10" set:html={icons[2]} />
    </div>
  </div>
</div>
