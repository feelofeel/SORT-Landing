---
import { ChevronDown, ChevronLeft, ChevronRight, ChevronUp } from "@lucide/astro";

interface Step {
	n: string;
	title: string;
	desc: string;
}

interface Props {
	steps: Step[];
}

const { steps } = Astro.props;

// Thin-line inline SVGs — stroke="currentColor" → works in light + dark mode
const icons = [
	// 1: Delivery truck — supply arrives in Poster
	`<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="2" y="11" width="22" height="15" rx="2"/>
    <path d="M24 16 h8 l4 10 v4 H24 V16z"/>
    <circle cx="10" cy="29" r="3.5"/>
    <circle cx="31" cy="29" r="3.5"/>
    <line x1="14" y1="29" x2="20" y2="29"/>
    <path d="M8 19.5 l2.5 2.5 l5-5"/>
  </svg>`,

	// 2: Shelving rack with batch tracking
	`<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="3" y1="4" x2="3" y2="32"/>
    <line x1="27" y1="4" x2="27" y2="32"/>
    <line x1="2" y1="13" x2="28" y2="13"/>
    <line x1="2" y1="23" x2="28" y2="23"/>
    <line x1="2" y1="32" x2="28" y2="32"/>
    <rect x="5"  y="5"  width="6" height="7" rx="1"/>
    <rect x="13" y="5"  width="6" height="7" rx="1"/>
    <rect x="21" y="5"  width="5" height="7" rx="1"/>
    <rect x="5"  y="14" width="6" height="8" rx="1"/>
    <rect x="13" y="15" width="6" height="7" rx="1"/>
    <circle cx="32" cy="30" r="6"/>
    <line  x1="36.2" y1="34.2" x2="39" y2="37"/>
    <path d="M29.5 32 v-3 M32 32 v-4.5 M34.5 32 v-2"/>
  </svg>`,

	// 3: Clipboard (left) + clock (right, fully clear of clipboard) — transparent shift
	`<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="2" y="5" width="18" height="25" rx="2"/>
    <rect x="7" y="2" width="8" height="6" rx="1.5"/>
    <path d="M6 16 l2.5 2.5 l4.5-4"/>
    <path d="M6 23 l2.5 2.5 l4.5-4"/>
    <circle cx="31" cy="30" r="8"/>
    <path d="M31 24.5 v5.8 l3.5 2.5"/>
  </svg>`,

	// 4: Tapping hand — write-off in one tap
	`<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <!-- Hand outline: extended index finger, three curled-finger bumps on right, palm at base -->
    <path d="M17 4 Q17 1 20 1 Q23 1 23 4 L23 18 Q26 18 26 22 Q29 22 29 26 L29 28 Q29 37 20 37 Q11 37 11 28 L11 26 Q11 22 14 22 Q14 18 17 18 Z"/>
    <!-- Thumb (curves left off the palm) -->
    <path d="M11 26 Q6 24 6 19 Q6 14 11 14"/>
    <!-- Subtle knuckle crease across index finger -->
    <line x1="17.5" y1="12" x2="22.5" y2="12" stroke-width="1.1"/>
    <!-- Two small tap-ripple arcs to right of fingertip -->
    <path d="M25 6 Q28 3.5 25 1" stroke-width="1.3"/>
    <path d="M27 8 Q31 4.5 27 1" stroke-width="1.1"/>
  </svg>`,
];

const arrowStyle = "color: var(--color-primary-light)";
---

<!-- Mobile: single column, sequential -->
<div class="md:hidden grid grid-cols-1 gap-3 mt-6 max-w-sm mx-auto">
  {steps.map((s, i) => (
    <div class="p-4 rounded-2xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700">
      <div class="flex items-start gap-3">
        <div class="shrink-0 w-8 h-8 rounded-lg bg-primary text-white font-brand text-sm flex items-center justify-center">
          {s.n}
        </div>
        <div class="min-w-0">
          <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100 mb-0.5">{s.title}</h3>
          <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">{s.desc}</p>
        </div>
      </div>
      {i < steps.length - 1 && (
        <div class="flex justify-center mt-2" style={arrowStyle}>
          <ChevronDown size={18} strokeWidth={2.5} />
        </div>
      )}
    </div>
  ))}
</div>

<!-- Desktop: 2×2 grid with SORT-style chevron arrows in the gaps -->
<div class="hidden md:grid mt-6 max-w-2xl mx-auto"
     style="grid-template-columns: 1fr 44px 1fr; grid-template-rows: auto 40px auto; gap: 0;">

  <!-- Row 1: card 1 · chevron-right · card 2 -->
  <div class="p-5 rounded-2xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700 m-1.5">
    <div class="w-9 h-9 rounded-xl bg-primary text-white font-brand text-base flex items-center justify-center mb-2">1</div>
    <div class="w-9 h-9 mb-2" style={arrowStyle} set:html={icons[0]} />
    <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100 mb-1">{steps[0].title}</h3>
    <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">{steps[0].desc}</p>
  </div>

  <div class="flex items-center justify-center" style={`grid-row:1; grid-column:2; ${arrowStyle}`}>
    <ChevronRight size={28} strokeWidth={2.5} />
  </div>

  <div class="p-5 rounded-2xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700 m-1.5">
    <div class="w-9 h-9 rounded-xl bg-primary text-white font-brand text-base flex items-center justify-center mb-2">2</div>
    <div class="w-9 h-9 mb-2" style={arrowStyle} set:html={icons[1]} />
    <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100 mb-1">{steps[1].title}</h3>
    <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">{steps[1].desc}</p>
  </div>

  <!-- Row 2: up chevron · empty · down chevron -->
  <div class="flex items-center justify-center" style={`grid-row:2; grid-column:1; ${arrowStyle}`}>
    <ChevronUp size={28} strokeWidth={2.5} />
  </div>
  <div style="grid-row:2; grid-column:2;"></div>
  <div class="flex items-center justify-center" style={`grid-row:2; grid-column:3; ${arrowStyle}`}>
    <ChevronDown size={28} strokeWidth={2.5} />
  </div>

  <!-- Row 3: card 4 · chevron-left · card 3 -->
  <div class="p-5 rounded-2xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700 m-1.5">
    <div class="w-9 h-9 rounded-xl bg-primary text-white font-brand text-base flex items-center justify-center mb-2">4</div>
    <div class="w-9 h-9 mb-2" style={arrowStyle} set:html={icons[3]} />
    <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100 mb-1">{steps[3].title}</h3>
    <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">{steps[3].desc}</p>
  </div>

  <div class="flex items-center justify-center" style={`grid-row:3; grid-column:2; ${arrowStyle}`}>
    <ChevronLeft size={28} strokeWidth={2.5} />
  </div>

  <div class="p-5 rounded-2xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700 m-1.5">
    <div class="w-9 h-9 rounded-xl bg-primary text-white font-brand text-base flex items-center justify-center mb-2">3</div>
    <div class="w-9 h-9 mb-2" style={arrowStyle} set:html={icons[2]} />
    <h3 class="text-sm font-semibold text-neutral-800 dark:text-neutral-100 mb-1">{steps[2].title}</h3>
    <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">{steps[2].desc}</p>
  </div>
</div>
