---
import { type Lang, getContent, homePath } from "@/i18n";

interface Props {
	lang?: Lang;
}
const { lang = "uk" } = Astro.props;
const c = getContent(lang);
---

<a
  href={homePath(lang)}
  class="group relative z-30 flex items-center gap-2.5 h-10"
  aria-label={c.logo.aria}
>
  <img
    src="/icons/icon.svg"
    alt="SORT"
    width="36"
    height="36"
    class="w-9 h-9 rounded-xl shadow-sm"
    loading="eager"
  />
  <span class="font-brand text-xl tracking-wide text-neutral-800 dark:text-neutral-100">SORT</span>
</a>
