---
// Plausible is the primary analytics for the landing (privacy-friendly, ~1KB, no cookie
// banner, deferred so it doesn't hurt INP). GA4/Umami kept as optional alternates.
const PLAUSIBLE_DOMAIN = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const GAID = import.meta.env.PUBLIC_GA4_ID;
const UMAMIId = import.meta.env.PUBLIC_UMAMI_ID;
---

<!-- Plausible -->
{PLAUSIBLE_DOMAIN && (
    <script defer is:inline data-domain={PLAUSIBLE_DOMAIN} src="https://plausible.io/js/script.tagged-events.js"></script>
)}
<!-- Event queue stub: lets custom events fire before/without the script (no-op if unconfigured) -->
<script is:inline>
    window.plausible = window.plausible || function () { (window.plausible.q = window.plausible.q || []).push(arguments) };
</script>

<!-- GA4 跟踪代码 -->
{GAID && (
    <>
      <script  is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GAID}`} ></script>
      <script  is:inline define:vars={{ GAID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', GAID);
      </script>
    </>
)}

<!-- UMAMIId 跟踪代码 -->
{UMAMIId && (
    <script
        async
        defer
        is:inline
        data-website-id={UMAMIId}
        src="https://cloud.umami.is/script.js"
    ></script>
)}

